DATABASE_URL=postgresql://postgres:your_password_here@127.0.0.1:55432/accident

# ===== Auth.js =====
AUTH_SECRET=change-this-auth-secret
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# ===== Health ID (moph.id.th) =====
HEALTH_CLIENT_ID=your-health-client-id
HEALTH_CLIENT_SECRET=your-health-client-secret
HEALTH_REDIRECT_URI=http://localhost:3000/api/auth/healthid

# ===== Provider ID (provider.id.th) =====
PROVIDER_CLIENT_ID=your-provider-client-id
PROVIDER_CLIENT_SECRET=your-provider-client-secret

# ================== API ==============
PATIENT_AES_SECRET=change-this-aes-secret
PATIENT_API_JWT_SECRET=change-this-patient-jwt-secret
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_SSL=false
NEXT_PUBLIC_PATIENT_REALTIME_MODE=auto
NEXT_PUBLIC_PATIENT_POLL_INTERVAL_MS=30000
NEXT_PUBLIC_PATIENT_STREAM_RETRY_MS=5000
PATIENT_STREAM_HEARTBEAT_MS=20000
PATIENT_STREAM_MAX_DURATION_MS=240000
